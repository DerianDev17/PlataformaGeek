---
import MainLayout from '@/layouts/MainLayout.astro';
import { Button } from '@/shared/ui';
import { ROUTES } from '@/shared/constants';
---

<MainLayout title="Página no encontrada" description="La pagina que buscas no existe o ha sido movida." noindex={true}>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <span class="text-7xl font-bold text-geek-border font-heading">404</span>
    <h1 class="text-2xl font-bold text-geek-text font-heading mt-4">Página no encontrada</h1>
    <p class="text-geek-text-secondary mt-2 max-w-md">
      La página que buscas no existe o ha sido movida. Verifica la URL o vuelve al inicio.
    </p>
    <div class="mt-6 flex gap-3">
      <a href={ROUTES.HOME}>
        <Button>Ir al inicio</Button>
      </a>
      <a href={ROUTES.UNIVERSES}>
        <Button variant="secondary">Explorar universos</Button>
      </a>
    </div>
  </div>
</MainLayout>
