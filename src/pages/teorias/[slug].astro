---
import MainLayout from '@/layouts/MainLayout.astro';
import { TheoryDetail } from '@/widgets/theory-detail';
import { Breadcrumb } from '@/shared/ui';
import { ROUTES } from '@/shared/constants';
import { getSlugPaths, loadPageData } from '@/shared/lib';
import type { Theory } from '@/entities/theory';

export async function getStaticPaths() {
  return getSlugPaths('/theories?limit=50', [
    'goku-vs-superman-quien-ganaria',
    'quien-sera-el-proximo-gran-villano-del-ucm',
  ]);
}

const { slug } = Astro.params;

const theory = await loadPageData<Theory | null>(`/theories/${slug}`, null);

if (!theory) {
  return Astro.redirect('/404');
}

const breadcrumbItems: Array<{ label: string; href?: string }> = [
  { label: 'Inicio', href: ROUTES.HOME },
  { label: 'Universos', href: ROUTES.UNIVERSES },
];

if (theory.universe) {
  breadcrumbItems.push({ label: theory.universe.name, href: ROUTES.UNIVERSE_DETAIL(theory.universe.slug) });
}

breadcrumbItems.push({ label: theory.title });
---

<MainLayout title={theory.title} description={theory.content?.slice(0, 160)}>
  <Breadcrumb
    items={breadcrumbItems}
  />

  <div class="mt-6">
    <TheoryDetail theory={theory} client:load />
  </div>
</MainLayout>
