---
import MainLayout from '@/layouts/MainLayout.astro';
import {
  HOME_IMAGES,
  ROUTES,
  SERIES_PAGE_STATS,
  SERIES_RADAR,
  SERIES_SPOTLIGHTS,
  SERIES_WATCH_PATHS,
} from '@/shared/constants';

const leadSeries = SERIES_SPOTLIGHTS[0];
---

<MainLayout title="Series" description="Ordenes de visionado, arcos y dossiers de series geek en NexoGeek">
  <section class="relative overflow-hidden rounded-lg border border-geek-border bg-geek-dark-secondary">
    <img
      src={HOME_IMAGES.universes['star wars']}
      alt=""
      class="absolute inset-0 h-full w-full object-cover opacity-48"
      loading="eager"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-geek-dark via-geek-dark/84 to-geek-dark/35" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-geek-dark-secondary to-transparent" aria-hidden="true"></div>

    <div class="relative grid min-h-[410px] gap-6 p-6 md:p-8 xl:grid-cols-[minmax(0,1fr)_380px] xl:p-10">
      <div class="flex max-w-3xl flex-col justify-center">
        <span class="mb-4 inline-flex w-fit rounded-lg border border-cyan-300/30 bg-cyan-300/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-cyan-100">
          Ordenes y arcos
        </span>
        <h1 class="text-4xl font-bold leading-tight text-white md:text-6xl">Series</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-geek-text-secondary md:text-lg">
          Una pagina para seguir temporadas, spin-offs y cronologias por saga. Esta vista prioriza rutas de visionado,
          arcos narrativos y contexto de canon, no resultados generales de explorar.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="#dossiers"
            class="btn-primary"
          >
            Ver dossiers
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href={ROUTES.ARTICLE_DETAIL('orden-cronologico-de-star-wars')}
            class="btn-secondary"
          >
            Abrir orden Star Wars
          </a>
        </div>
      </div>

      <aside class="self-end rounded-lg border border-geek-border bg-geek-dark/76 p-4 backdrop-blur">
        <p class="text-xs uppercase tracking-wide text-geek-text-secondary">Dossier principal</p>
        <img src={leadSeries.image} alt={leadSeries.title} class="mt-3 aspect-[16/9] w-full rounded-lg object-cover" />
        <h2 class="mt-4 text-xl font-bold text-white">{leadSeries.title}</h2>
        <p class="mt-2 text-sm leading-6 text-geek-text-secondary">{leadSeries.summary}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{leadSeries.format}</span>
          <span class="rounded-md border border-geek-border bg-geek-dark-secondary px-2 py-1 text-xs text-geek-text-secondary">{leadSeries.pace}</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4" aria-label="Metricas de series">
    {SERIES_PAGE_STATS.map((stat) => (
      <div class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <span class="block text-2xl font-bold text-white">{stat.value}</span>
        <span class="block text-sm font-semibold text-geek-text">{stat.label}</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">{stat.detail}</span>
      </div>
    ))}
  </section>

  <div class="mt-8 grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
    <div class="min-w-0 space-y-8">
      <section id="dossiers">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold text-white">Dossiers de series</h2>
            <p class="mt-1 text-sm text-geek-text-secondary">Sagas organizadas por orden, conflicto y formato para saltar entre temporadas sin perder contexto.</p>
          </div>
          <a href={ROUTES.EXPLORE} class="text-sm font-semibold text-geek-accent transition-colors hover:text-geek-accent-secondary">Explorar mas</a>
        </div>

        <div class="grid gap-4 lg:grid-cols-3">
          {SERIES_SPOTLIGHTS.map((item) => (
            <a href={item.href} class="group overflow-hidden rounded-lg border border-geek-border bg-geek-dark-secondary transition-colors hover:border-geek-accent/70 focus-visible:ring-2 focus-visible:ring-geek-accent">
              <div class="relative aspect-[16/10] overflow-hidden">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-geek-dark-secondary via-geek-dark-secondary/25 to-transparent" aria-hidden="true"></div>
                <span class="absolute left-3 top-3 rounded-md border border-geek-border bg-geek-dark/78 px-2.5 py-1 text-xs font-semibold text-geek-text">{item.universe}</span>
              </div>
              <div class="p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-cyan-100">{item.format}</p>
                <h3 class="mt-1 line-clamp-2 text-lg font-bold text-white group-hover:text-geek-accent-secondary">{item.title}</h3>
                <p class="mt-2 line-clamp-3 text-sm leading-6 text-geek-text-secondary">{item.summary}</p>
                <span class="mt-4 inline-flex rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{item.pace}</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section>
        <div class="mb-4">
          <h2 class="text-2xl font-bold text-white">Orden de trabajo</h2>
          <p class="mt-1 text-sm text-geek-text-secondary">Como estructurar una guia de series antes de publicarla o conectarla a un universo.</p>
        </div>

        <div class="grid gap-3 md:grid-cols-2">
          {SERIES_WATCH_PATHS.map((step) => (
            <div class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
              <div class="flex items-start gap-4">
                <span class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-lg border border-cyan-300/30 bg-cyan-300/10 font-mono text-sm font-bold text-cyan-100">
                  {step.step}
                </span>
                <div>
                  <h3 class="text-lg font-bold text-white">{step.title}</h3>
                  <p class="mt-1 text-sm leading-6 text-geek-text-secondary">{step.detail}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>

    <aside class="space-y-4 xl:sticky xl:top-24 xl:self-start">
      <section class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <h2 class="text-base font-bold text-white">Radar de sagas</h2>
        <div class="mt-4 space-y-2">
          {SERIES_RADAR.map((item) => (
            <a href={item.href} class="flex items-center justify-between rounded-lg border border-transparent px-3 py-2 transition-colors hover:border-geek-border hover:bg-geek-dark">
              <span class="text-sm font-semibold text-geek-text">{item.label}</span>
              <span class="rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{item.count}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <h2 class="text-base font-bold text-white">Control de continuidad</h2>
        <div class="mt-4 space-y-3 text-sm text-geek-text-secondary">
          <p class="rounded-lg border border-geek-border bg-geek-dark p-3">Marca temporadas, especiales y spin-offs por era narrativa.</p>
          <p class="rounded-lg border border-geek-border bg-geek-dark p-3">Distingue canon principal, adaptacion y material complementario.</p>
          <p class="rounded-lg border border-geek-border bg-geek-dark p-3">Conecta cada guia con universos y personajes ya publicados.</p>
        </div>
      </section>

      <a href={ROUTES.CREATE_ARTICLE} class="block rounded-lg border border-geek-accent/30 bg-geek-accent/10 p-4 transition-colors hover:border-geek-accent/60 hover:bg-geek-accent/15">
        <span class="text-base font-bold text-white">Publica un orden</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">Crea una guia de episodios, temporadas o cronologia.</span>
        <span class="mt-4 inline-flex text-sm font-semibold text-geek-accent">Crear articulo</span>
      </a>
    </aside>
  </div>
</MainLayout>
