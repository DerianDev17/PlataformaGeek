---
import MainLayout from '@/layouts/MainLayout.astro';
import {
  COMIC_CHARACTER_SLUGS,
  COMIC_EVENT_STACK,
  COMIC_PAGE_STATS,
  COMIC_READING_LANES,
  HOME_IMAGES,
  ROUTES,
  getFallbackCharacterBySlug,
} from '@/shared/constants';

const comicCharacters = COMIC_CHARACTER_SLUGS.map((slug) => getFallbackCharacterBySlug(slug)).filter(Boolean);
const primaryReading = COMIC_READING_LANES[0];
---

<MainLayout title="Comics" description="Guias editoriales de comics, heroes, villanos, eventos y continuidad en NexoGeek">
  <section class="relative overflow-hidden rounded-lg border border-geek-border bg-geek-dark-secondary">
    <img
      src={HOME_IMAGES.universes.marvel}
      alt=""
      class="absolute inset-0 h-full w-full object-cover opacity-50"
      loading="eager"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-geek-dark via-geek-dark/86 to-geek-dark/38" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-geek-dark-secondary to-transparent" aria-hidden="true"></div>

    <div class="relative grid min-h-[410px] gap-6 p-6 md:p-8 xl:grid-cols-[minmax(0,1fr)_380px] xl:p-10">
      <div class="flex max-w-3xl flex-col justify-center">
        <span class="mb-4 inline-flex w-fit rounded-lg border border-geek-accent/30 bg-geek-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-geek-accent">
          Continuidad y eventos
        </span>
        <h1 class="text-4xl font-bold leading-tight text-white md:text-6xl">Comics</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-geek-text-secondary md:text-lg">
          Un tablero para entrar a heroes, villanos, crossovers y lineas temporales sin depender del buscador de explorar.
          Aqui las lecturas se agrupan por continuidad, impacto y personajes implicados.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="#lecturas"
            class="inline-flex h-11 items-center gap-2 rounded-lg bg-geek-accent-hover px-5 text-sm font-bold text-white transition-colors hover:bg-geek-accent focus-visible:ring-2 focus-visible:ring-geek-accent"
          >
            Lecturas clave
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href={ROUTES.UNIVERSE_DETAIL('marvel')}
            class="inline-flex h-11 items-center rounded-lg border border-geek-border bg-geek-dark-secondary/80 px-5 text-sm font-semibold text-geek-text transition-colors hover:border-geek-accent/70 hover:bg-geek-dark-tertiary focus-visible:ring-2 focus-visible:ring-geek-accent"
          >
            Abrir Marvel
          </a>
        </div>
      </div>

      <aside class="self-end overflow-hidden rounded-lg border border-geek-border bg-geek-dark/76 backdrop-blur">
        <div class="relative aspect-[16/9] overflow-hidden">
          <img src={primaryReading.image} alt={primaryReading.title} class="h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-geek-dark to-transparent" aria-hidden="true"></div>
          <span class="absolute left-4 top-4 rounded-md bg-geek-accent-hover px-2.5 py-1 text-xs font-bold text-white">{primaryReading.eyebrow}</span>
        </div>
        <div class="p-4">
          <p class="text-xs uppercase tracking-wide text-geek-text-secondary">Entrada recomendada</p>
          <h2 class="mt-1 text-xl font-bold text-white">{primaryReading.title}</h2>
          <p class="mt-2 text-sm leading-6 text-geek-text-secondary">{primaryReading.summary}</p>
          <a href={primaryReading.href} class="mt-4 inline-flex text-sm font-semibold text-geek-accent transition-colors hover:text-geek-accent-secondary">
            Leer guia
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4" aria-label="Metricas de comics">
    {COMIC_PAGE_STATS.map((stat) => (
      <div class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <span class="block text-2xl font-bold text-white">{stat.value}</span>
        <span class="block text-sm font-semibold text-geek-text">{stat.label}</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">{stat.detail}</span>
      </div>
    ))}
  </section>

  <div class="mt-8 grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
    <div class="min-w-0 space-y-8">
      <section id="lecturas">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold text-white">Lecturas clave</h2>
            <p class="mt-1 text-sm text-geek-text-secondary">Tres rutas para entender personajes, objetos y cronologias sin perder continuidad.</p>
          </div>
          <a href={ROUTES.ARTICLES} class="text-sm font-semibold text-geek-accent transition-colors hover:text-geek-accent-secondary">Ver articulos</a>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {COMIC_READING_LANES.map((item) => (
            <a href={item.href} class="group overflow-hidden rounded-lg border border-geek-border bg-geek-dark-secondary transition-colors hover:border-geek-accent/70 focus-visible:ring-2 focus-visible:ring-geek-accent">
              <div class="relative aspect-[16/10] overflow-hidden">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-geek-dark-secondary via-geek-dark-secondary/30 to-transparent" aria-hidden="true"></div>
                <span class="absolute left-3 top-3 rounded-md border border-geek-border bg-geek-dark/78 px-2.5 py-1 text-xs font-semibold text-geek-text">{item.metric}</span>
              </div>
              <div class="p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-geek-accent">{item.eyebrow}</p>
                <h3 class="mt-1 line-clamp-2 text-lg font-bold text-white group-hover:text-geek-accent-secondary">{item.title}</h3>
                <p class="mt-2 line-clamp-3 text-sm leading-6 text-geek-text-secondary">{item.summary}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section>
        <div class="mb-4">
          <h2 class="text-2xl font-bold text-white">Heroes y villanos conectados</h2>
          <p class="mt-1 text-sm text-geek-text-secondary">Perfiles que aparecen en sagas de equipo, amenazas cosmicas y relatos urbanos.</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 2xl:grid-cols-3">
          {comicCharacters.map((character: any) => (
            <a href={ROUTES.CHARACTER_DETAIL(character.slug)} class="group grid grid-cols-[88px_minmax(0,1fr)] gap-4 rounded-lg border border-geek-border bg-geek-dark-secondary p-3 transition-colors hover:border-geek-accent/70 focus-visible:ring-2 focus-visible:ring-geek-accent">
              <img src={character.imageUrl} alt={character.name} class="h-24 w-full rounded-md object-cover" loading="lazy" />
              <span class="min-w-0">
                <span class="block truncate text-lg font-bold text-white group-hover:text-geek-accent-secondary">{character.name}</span>
                <span class="mt-0.5 block truncate text-sm text-geek-accent">{character.alias}</span>
                <span class="mt-2 block line-clamp-2 text-sm leading-5 text-geek-text-secondary">{character.description}</span>
                <span class="mt-3 inline-flex rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{character.role}</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    </div>

    <aside class="space-y-4 xl:sticky xl:top-24 xl:self-start">
      <section class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <h2 class="text-base font-bold text-white">Mapa de continuidad</h2>
        <div class="mt-4 space-y-3">
          {COMIC_EVENT_STACK.map((event, index) => (
            <a href={event.href} class="block rounded-lg border border-geek-border bg-geek-dark p-3 transition-colors hover:border-geek-accent/60">
              <span class="flex items-start gap-3">
                <span class="grid h-8 w-8 flex-shrink-0 place-items-center rounded-lg bg-geek-accent/10 font-mono text-xs font-bold text-geek-accent">
                  {index + 1}
                </span>
                <span class="min-w-0">
                  <span class="block text-sm font-bold text-white">{event.title}</span>
                  <span class="mt-1 inline-flex rounded-md bg-geek-dark-tertiary px-2 py-0.5 text-xs text-geek-text-secondary">{event.status}</span>
                  <span class="mt-2 block text-sm leading-5 text-geek-text-secondary">{event.summary}</span>
                </span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <h2 class="text-base font-bold text-white">Checklist editorial</h2>
        <div class="mt-4 space-y-3 text-sm text-geek-text-secondary">
          <p class="rounded-lg border border-geek-border bg-geek-dark p-3">Identifica si el articulo usa canon principal, variante o adaptacion.</p>
          <p class="rounded-lg border border-geek-border bg-geek-dark p-3">Conecta cada evento con sus personajes clave y objetos recurrentes.</p>
          <p class="rounded-lg border border-geek-border bg-geek-dark p-3">Separa spoilers de guias de entrada para lectores nuevos.</p>
        </div>
      </section>

      <a href={ROUTES.CREATE_ARTICLE} class="block rounded-lg border border-geek-accent/30 bg-geek-accent/10 p-4 transition-colors hover:border-geek-accent/60 hover:bg-geek-accent/15">
        <span class="text-base font-bold text-white">Documenta un evento</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">Publica una guia de lectura, personaje o crossover.</span>
        <span class="mt-4 inline-flex text-sm font-semibold text-geek-accent">Crear articulo</span>
      </a>
    </aside>
  </div>
</MainLayout>
