---
import MainLayout from '@/layouts/MainLayout.astro';
import { ProfileEditor } from '@/widgets/profile-editor';
---

<MainLayout title="Mi cuenta" description="Edita tu perfil de NexoGeek" noindex>
  <div class="mx-auto max-w-3xl">
    <div class="mb-8">
      <h1 class="font-heading text-3xl font-bold text-geek-text">Mi cuenta</h1>
      <p class="mt-2 text-geek-text-secondary">
        Actualiza tu informacion personal. Los cambios se veran reflejados inmediatamente en tu perfil publico.
      </p>
    </div>

    <ProfileEditor client:only="react" />
  </div>
</MainLayout>
