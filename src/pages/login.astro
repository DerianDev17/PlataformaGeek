---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { LoginFormWithAuth } from '@/shared/ui/LoginForm';
---

<AuthLayout title="Iniciar sesion" description="Accede a tu cuenta de NexoGeek">
  <div class="w-full max-w-md">
    <h1 class="mb-6 text-center font-heading text-2xl font-bold text-geek-text">Iniciar sesion</h1>
    <LoginFormWithAuth client:only="react" />
    <p class="mt-6 text-center text-sm text-geek-text-secondary">
      No tienes cuenta?{' '}
      <a href="/registro" class="font-medium text-geek-accent hover:text-geek-accent-hover">Registrate</a>
    </p>
  </div>
</AuthLayout>
