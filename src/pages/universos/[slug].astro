---
import MainLayout from '@/layouts/MainLayout.astro';
import { UniverseDetail } from '@/widgets/universe-detail';
import { Breadcrumb } from '@/shared/ui';
import {
  EXPLORE_ITEMS,
  FALLBACK_CHARACTERS,
  FALLBACK_UNIVERSES,
  getFallbackUniverseBySlug,
  getMarvelUniverseDetail,
  normalizeUniverseForShowcase,
  ROUTES,
  type ShowcaseUniverse,
} from '@/shared/constants';
import { getSlugPaths, loadPageData } from '@/shared/lib';

type UniversePageData = {
  id: string;
  name: string;
  slug: string;
  description: string;
  coverImage: string | null;
  bannerImage: string | null;
  articleCount: number;
  characterCount: number;
  theoryCount: number;
  recentArticles?: Array<{
    id: string;
    title: string;
    slug: string;
    summary: string;
    coverImage: string | null;
    views: number;
    createdAt: string;
  }>;
  featuredCharacters?: Array<{
    id: string;
    name: string;
    slug: string;
    alias: string | null;
    imageUrl: string | null;
    description: string;
  }>;
  popularTheories?: Array<{
    id: string;
    title: string;
    slug: string;
    content: string;
    status: string;
    votes: number;
    createdAt: string;
    author: { username: string; avatarUrl: string | null };
  }>;
  category?: ShowcaseUniverse['category'];
  momentum?: string;
  editors?: number;
};

export async function getStaticPaths() {
  return getSlugPaths('/universes?limit=50', FALLBACK_UNIVERSES.map((universe) => universe.slug));
}

const { slug } = Astro.params;

function buildFallbackDetail(universe: ShowcaseUniverse): UniversePageData {
  const relatedItems = EXPLORE_ITEMS.filter((item) => item.category === universe.category).slice(0, 3);
  const articles = relatedItems.length > 0 ? relatedItems : EXPLORE_ITEMS.slice(0, 3);
  const universeCharacters = FALLBACK_CHARACTERS.filter((character) => character.universe.slug === universe.slug).slice(0, 3);
  const featuredCharacters = universeCharacters.length > 0
    ? universeCharacters.map((character) => ({
        id: character.id,
        name: character.name,
        slug: character.slug,
        alias: character.alias,
        imageUrl: character.imageUrl,
        description: character.description,
      }))
    : [
        {
          id: `${universe.slug}-protagonista`,
          name: `Figura clave de ${universe.name}`,
          slug: `${universe.slug}-figura-clave`,
          alias: 'Protagonista',
          imageUrl: universe.coverImage,
          description: `Perfil editorial para entender los conflictos principales de ${universe.name}.`,
        },
        {
          id: `${universe.slug}-antagonista`,
          name: `Rival central`,
          slug: `${universe.slug}-rival-central`,
          alias: 'Antagonista',
          imageUrl: universe.bannerImage,
          description: `Personaje usado como eje para teorias, arcos y debates de continuidad.`,
        },
        {
          id: `${universe.slug}-mentor`,
          name: `Guia de lore`,
          slug: `${universe.slug}-guia-lore`,
          alias: 'Referente',
          imageUrl: universe.coverImage,
          description: `Entrada base para conectar eventos, lugares y personajes secundarios.`,
        },
      ];

  return {
    ...universe,
    coverImage: universe.coverImage,
    bannerImage: universe.bannerImage,
    recentArticles: articles.map((item, index) => ({
      id: item.id,
      title: item.title,
      slug: item.href.split('/').filter(Boolean).pop() || item.id,
      summary: item.summary,
      coverImage: item.image,
      views: 7600 + index * 4300,
      createdAt: new Date(Date.UTC(2026, 5, 27 - index, 14, 0, 0)).toISOString(),
    })),
    featuredCharacters,
    popularTheories: [
      {
        id: `${universe.slug}-teoria-1`,
        title: `La cronologia oculta de ${universe.name}`,
        slug: `${universe.slug}-cronologia-oculta`,
        content: `Analisis de pistas, eventos y contradicciones internas del universo ${universe.name}.`,
        status: 'debated',
        votes: 248,
        createdAt: '2026-06-26T18:30:00.000Z',
        author: { username: 'LoreKeeper', avatarUrl: null },
      },
      {
        id: `${universe.slug}-teoria-2`,
        title: `Conexion entre sagas principales`,
        slug: `${universe.slug}-conexion-sagas`,
        content: 'Hipotesis sobre eventos que conectan etapas separadas del canon.',
        status: 'open',
        votes: 173,
        createdAt: '2026-06-25T12:15:00.000Z',
        author: { username: 'NekoGirl', avatarUrl: null },
      },
    ],
  };
}

const apiUniverse = await loadPageData<UniversePageData | null>(`/universes/${slug}`, null);
const fallbackUniverse = getFallbackUniverseBySlug(slug);
const normalizedApiUniverse = apiUniverse ? normalizeUniverseForShowcase(apiUniverse) : null;
const universe = apiUniverse || (slug === 'marvel' ? getMarvelUniverseDetail() : fallbackUniverse ? buildFallbackDetail(normalizedApiUniverse || fallbackUniverse) : null);

if (!universe) {
  return Astro.redirect('/404');
}
---

<MainLayout title={universe.name} description={universe.description}>
  <Breadcrumb
    items={[
      { label: 'Inicio', href: ROUTES.HOME },
      { label: 'Universos', href: ROUTES.UNIVERSES },
      { label: universe.name },
    ]}
  />

  <div class="mt-4">
    <UniverseDetail universe={universe} client:load />
  </div>
</MainLayout>
