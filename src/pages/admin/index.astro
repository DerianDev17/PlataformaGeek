---
import MainLayout from '@/layouts/MainLayout.astro';
import { Card } from '@/shared/ui';
import { AdminPanel } from '@/widgets/admin-panel';
import { loadPageData } from '@/shared/lib';

type AdminStats = {
  users?: number;
  activeUsers?: number;
  publishedArticles?: number;
  universes?: number;
  comments?: number;
  theories?: number;
  pendingRevisions?: number;
};

function isRecord(value: unknown): value is Record<string, unknown> {
  return typeof value === 'object' && value !== null && !Array.isArray(value);
}

function isAdminStats(value: unknown): value is AdminStats {
  return isRecord(value);
}

const apiData = await loadPageData<unknown>('/admin/stats', null);
const stats: AdminStats | null = isRecord(apiData) && isAdminStats(apiData.counts)
  ? apiData.counts
  : isAdminStats(apiData)
    ? apiData
    : null;
---

<MainLayout title="Panel Admin" description="Panel de administración de NexoGeek" noindex={true}>
  <h1 class="text-3xl font-bold text-geek-text font-heading mb-8">Panel de administración</h1>

  {stats && (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-10">
      <Card>
        <p class="text-sm text-geek-text-secondary">Usuarios totales</p>
        <p class="text-2xl font-bold text-geek-text mt-1">{stats?.users || 0}</p>
      </Card>
      <Card>
        <p class="text-sm text-geek-text-secondary">Activos</p>
        <p class="text-2xl font-bold text-geek-text mt-1">{stats?.activeUsers || 0}</p>
      </Card>
      <Card>
        <p class="text-sm text-geek-text-secondary">Artículos</p>
        <p class="text-2xl font-bold text-geek-text mt-1">{stats?.publishedArticles || 0}</p>
      </Card>
      <Card>
        <p class="text-sm text-geek-text-secondary">Universos</p>
        <p class="text-2xl font-bold text-geek-text mt-1">{stats?.universes || 0}</p>
      </Card>
      <Card>
        <p class="text-sm text-geek-text-secondary">Comentarios</p>
        <p class="text-2xl font-bold text-geek-text mt-1">{stats?.comments || 0}</p>
      </Card>
      <Card>
        <p class="text-sm text-geek-text-secondary">Teorías</p>
        <p class="text-2xl font-bold text-geek-text mt-1">{stats?.theories || 0}</p>
      </Card>
      <Card>
        <p class="text-sm text-geek-text-secondary">Pendientes de revisión</p>
        <p class="text-2xl font-bold text-geek-warning mt-1">{stats?.pendingRevisions || 0}</p>
      </Card>
    </div>
  )}

  <AdminPanel client:only="react" />
</MainLayout>
