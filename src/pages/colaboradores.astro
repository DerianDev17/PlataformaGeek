---
import MainLayout from '@/layouts/MainLayout.astro';
import {
  COLLABORATOR_PAGE_STATS,
  COLLABORATOR_PROFILES,
  COLLABORATOR_PROGRAMS,
  HOME_IMAGES,
  ROUTES,
} from '@/shared/constants';

const leadCollaborator = COLLABORATOR_PROFILES[0];
---

<MainLayout title="Colaboradores" description="Equipo de colaboradores, roles editoriales y programas de contribucion de NexoGeek">
  <section class="relative overflow-hidden rounded-lg border border-geek-border bg-geek-dark-secondary">
    <img src={HOME_IMAGES.hero} alt="" class="absolute inset-0 h-full w-full object-cover opacity-44" loading="eager" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-r from-geek-dark via-geek-dark/86 to-geek-dark/36" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-geek-dark-secondary to-transparent" aria-hidden="true"></div>

    <div class="relative grid min-h-[405px] gap-6 p-6 md:p-8 xl:grid-cols-[minmax(0,1fr)_380px] xl:p-10">
      <div class="flex max-w-3xl flex-col justify-center">
        <span class="mb-4 inline-flex w-fit rounded-lg border border-geek-accent/30 bg-geek-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-geek-accent">
          Comunidad editorial
        </span>
        <h1 class="text-4xl font-bold leading-tight text-white md:text-6xl">Colaboradores</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-geek-text-secondary md:text-lg">
          Perfiles destacados, roles y programas para quienes construyen articulos, guias, debates y cobertura dentro de NexoGeek.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#equipo" class="btn-primary">
            Ver equipo
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a href={ROUTES.RANKING} class="btn-secondary">
            Ver ranking
          </a>
        </div>
      </div>

      <aside class="self-end rounded-lg border border-geek-border bg-geek-dark/76 p-4 backdrop-blur">
        <p class="text-xs uppercase tracking-wide text-geek-text-secondary">Colaborador destacado</p>
        <div class="mt-4 flex items-start gap-4">
          <span class="grid h-14 w-14 flex-shrink-0 place-items-center rounded-full bg-geek-accent/15 text-lg font-bold text-geek-accent">{leadCollaborator.displayName.slice(0, 1)}</span>
          <span class="min-w-0">
            <h2 class="text-xl font-bold text-white">{leadCollaborator.displayName}</h2>
            <p class="mt-1 text-sm font-semibold text-geek-accent">{leadCollaborator.role}</p>
            <p class="mt-2 text-sm leading-6 text-geek-text-secondary">{leadCollaborator.summary}</p>
          </span>
        </div>
        <div class="mt-4 grid grid-cols-3 gap-2 text-center">
          <span class="rounded-lg border border-geek-border bg-geek-dark-secondary p-2">
            <span class="block text-lg font-bold text-white">#{leadCollaborator.rank}</span>
            <span class="text-xs text-geek-text-secondary">rank</span>
          </span>
          <span class="rounded-lg border border-geek-border bg-geek-dark-secondary p-2">
            <span class="block text-lg font-bold text-white">{leadCollaborator.level}</span>
            <span class="text-xs text-geek-text-secondary">nivel</span>
          </span>
          <span class="rounded-lg border border-geek-border bg-geek-dark-secondary p-2">
            <span class="block text-lg font-bold text-white">{leadCollaborator.articleCount}</span>
            <span class="text-xs text-geek-text-secondary">posts</span>
          </span>
        </div>
      </aside>
    </div>
  </section>

  <section class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4" aria-label="Metricas de colaboradores">
    {COLLABORATOR_PAGE_STATS.map((stat) => (
      <div class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <span class="block text-2xl font-bold text-white">{stat.value}</span>
        <span class="block text-sm font-semibold text-geek-text">{stat.label}</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">{stat.detail}</span>
      </div>
    ))}
  </section>

  <div class="mt-8 grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
    <div class="min-w-0 space-y-8">
      <section id="equipo">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold text-white">Equipo destacado</h2>
            <p class="mt-1 text-sm text-geek-text-secondary">Perfiles con rol, foco editorial y contribuciones visibles.</p>
          </div>
          <a href={ROUTES.RANKING} class="text-sm font-semibold text-geek-accent transition-colors hover:text-geek-accent-secondary">Ver ranking completo</a>
        </div>

        <div class="grid gap-4 lg:grid-cols-2">
          {COLLABORATOR_PROFILES.map((profile) => (
            <a href={profile.href} class="group rounded-lg border border-geek-border bg-geek-dark-secondary p-4 transition-colors hover:border-geek-accent/70 focus-visible:ring-2 focus-visible:ring-geek-accent">
              <div class="flex items-start gap-4">
                <span class="grid h-12 w-12 flex-shrink-0 place-items-center rounded-full bg-geek-accent/15 text-sm font-bold text-geek-accent">{profile.displayName.slice(0, 1)}</span>
                <span class="min-w-0 flex-1">
                  <span class="flex flex-wrap items-center gap-2">
                    <span class="text-lg font-bold text-white group-hover:text-geek-accent-secondary">{profile.displayName}</span>
                    <span class="rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{profile.badge}</span>
                  </span>
                  <span class="mt-1 block text-sm font-semibold text-geek-text">{profile.role}</span>
                  <span class="mt-2 block text-sm leading-6 text-geek-text-secondary">{profile.summary}</span>
                </span>
              </div>
              <div class="mt-4 grid grid-cols-3 gap-2 text-sm">
                <span class="rounded-lg border border-geek-border bg-geek-dark p-2">
                  <span class="block font-bold text-white">{profile.xp.toLocaleString('en-US')}</span>
                  <span class="text-xs text-geek-text-secondary">XP</span>
                </span>
                <span class="rounded-lg border border-geek-border bg-geek-dark p-2">
                  <span class="block font-bold text-white">Nivel {profile.level}</span>
                  <span class="text-xs text-geek-text-secondary">progreso</span>
                </span>
                <span class="rounded-lg border border-geek-border bg-geek-dark p-2">
                  <span class="block font-bold text-white">{profile.articleCount}</span>
                  <span class="text-xs text-geek-text-secondary">articulos</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>

    <aside class="space-y-4 xl:sticky xl:top-24 xl:self-start">
      <section class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <h2 class="text-base font-bold text-white">Programas</h2>
        <div class="mt-4 space-y-3">
          {COLLABORATOR_PROGRAMS.map((program) => (
            <div class="rounded-lg border border-geek-border bg-geek-dark p-3">
              <span class="rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{program.metric}</span>
              <h3 class="mt-3 text-sm font-bold text-white">{program.title}</h3>
              <p class="mt-1 text-sm leading-5 text-geek-text-secondary">{program.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <a href={ROUTES.CREATE_ARTICLE} class="block rounded-lg border border-geek-accent/30 bg-geek-accent/10 p-4 transition-colors hover:border-geek-accent/60 hover:bg-geek-accent/15">
        <span class="text-base font-bold text-white">Empieza a colaborar</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">Publica una guia, mejora un articulo o participa en foros.</span>
        <span class="mt-4 inline-flex text-sm font-semibold text-geek-accent">Crear articulo</span>
      </a>
    </aside>
  </div>
</MainLayout>
