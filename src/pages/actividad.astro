---
import MainLayout from '@/layouts/MainLayout.astro';
import {
  ACTIVITY_FEED_ITEMS,
  ACTIVITY_LANES,
  ACTIVITY_PAGE_STATS,
  ACTIVITY_RADAR,
  HOME_IMAGES,
  ROUTES,
} from '@/shared/constants';

const leadActivity = ACTIVITY_FEED_ITEMS[0];
---

<MainLayout title="Actividad" description="Pulso reciente de ediciones, comentarios y revisiones de la comunidad NexoGeek">
  <section class="relative overflow-hidden rounded-lg border border-geek-border bg-geek-dark-secondary">
    <img src={HOME_IMAGES.articles[0]} alt="" class="absolute inset-0 h-full w-full object-cover opacity-42" loading="eager" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-r from-geek-dark via-geek-dark/88 to-geek-dark/40" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-geek-dark-secondary to-transparent" aria-hidden="true"></div>

    <div class="relative grid min-h-[390px] gap-6 p-6 md:p-8 xl:grid-cols-[minmax(0,1fr)_380px] xl:p-10">
      <div class="flex max-w-3xl flex-col justify-center">
        <span class="mb-4 inline-flex w-fit rounded-lg border border-cyan-300/30 bg-cyan-300/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-cyan-100">
          Comunidad en vivo
        </span>
        <h1 class="text-4xl font-bold leading-tight text-white md:text-6xl">Actividad</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-geek-text-secondary md:text-lg">
          Un tablero para seguir ediciones, comentarios, altas de articulos y revisiones sin convertirlo en una busqueda generica.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#pulso" class="btn-primary">
            Ver pulso
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a href={ROUTES.FORUMS} class="btn-secondary">
            Abrir foros
          </a>
        </div>
      </div>

      <aside class="self-end rounded-lg border border-geek-border bg-geek-dark/76 p-4 backdrop-blur">
        <p class="text-xs uppercase tracking-wide text-geek-text-secondary">Ahora mismo</p>
        <h2 class="mt-2 text-xl font-bold text-white">{leadActivity.user} {leadActivity.action}</h2>
        <a href={leadActivity.href} class="mt-1 block text-lg font-bold text-geek-accent transition-colors hover:text-geek-accent-secondary">{leadActivity.target}</a>
        <p class="mt-3 text-sm leading-6 text-geek-text-secondary">{leadActivity.detail}</p>
        <div class="mt-4 flex items-center justify-between rounded-lg border border-geek-border bg-geek-dark-secondary p-3">
          <span class="text-sm text-geek-text-secondary">{leadActivity.time}</span>
          <span class="rounded-md bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">{leadActivity.status}</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4" aria-label="Metricas de actividad">
    {ACTIVITY_PAGE_STATS.map((stat) => (
      <div class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <span class="block text-2xl font-bold text-white">{stat.value}</span>
        <span class="block text-sm font-semibold text-geek-text">{stat.label}</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">{stat.detail}</span>
      </div>
    ))}
  </section>

  <div class="mt-8 grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
    <div class="min-w-0 space-y-8">
      <section id="pulso">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold text-white">Pulso de comunidad</h2>
            <p class="mt-1 text-sm text-geek-text-secondary">Actividad reciente con contexto editorial y destino directo.</p>
          </div>
          <a href={ROUTES.COLLABORATORS} class="text-sm font-semibold text-geek-accent transition-colors hover:text-geek-accent-secondary">Ver colaboradores</a>
        </div>

        <div class="space-y-3">
          {ACTIVITY_FEED_ITEMS.map((item) => (
            <a href={item.href} class="group grid gap-4 rounded-lg border border-geek-border bg-geek-dark-secondary p-4 transition-colors hover:border-geek-accent/70 focus-visible:ring-2 focus-visible:ring-geek-accent md:grid-cols-[48px_minmax(0,1fr)_120px]">
              <span class="grid h-12 w-12 place-items-center rounded-full bg-geek-accent/15 text-sm font-bold text-geek-accent">{item.user.slice(0, 1)}</span>
              <span class="min-w-0">
                <span class="block text-sm text-geek-text-secondary">
                  <strong class="text-white">{item.user}</strong> {item.action}
                </span>
                <span class="mt-1 block truncate text-lg font-bold text-white group-hover:text-geek-accent-secondary">{item.target}</span>
                <span class="mt-1 block text-sm leading-6 text-geek-text-secondary">{item.detail}</span>
              </span>
              <span class="flex items-start justify-between gap-3 md:block md:text-right">
                <span class="rounded-md bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">{item.status}</span>
                <span class="mt-2 block text-xs text-geek-text-secondary">{item.time}</span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section>
        <div class="mb-4">
          <h2 class="text-2xl font-bold text-white">Canales de seguimiento</h2>
          <p class="mt-1 text-sm text-geek-text-secondary">Tres vistas para separar movimiento, debate y pendientes.</p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {ACTIVITY_LANES.map((lane) => (
            <a href={lane.href} class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4 transition-colors hover:border-geek-accent/60">
              <span class="rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{lane.metric}</span>
              <h3 class="mt-4 text-lg font-bold text-white">{lane.title}</h3>
              <p class="mt-2 text-sm leading-6 text-geek-text-secondary">{lane.detail}</p>
            </a>
          ))}
        </div>
      </section>
    </div>

    <aside class="space-y-4 xl:sticky xl:top-24 xl:self-start">
      <section class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <h2 class="text-base font-bold text-white">Radar activo</h2>
        <div class="mt-4 space-y-2">
          {ACTIVITY_RADAR.map((item) => (
            <a href={item.href} class="flex items-center justify-between rounded-lg border border-transparent px-3 py-2 transition-colors hover:border-geek-border hover:bg-geek-dark">
              <span class="text-sm font-semibold text-geek-text">{item.label}</span>
              <span class="rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{item.count}</span>
            </a>
          ))}
        </div>
      </section>

      <a href={ROUTES.CREATE_ARTICLE} class="block rounded-lg border border-geek-accent/30 bg-geek-accent/10 p-4 transition-colors hover:border-geek-accent/60 hover:bg-geek-accent/15">
        <span class="text-base font-bold text-white">Suma una actualizacion</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">Publica un articulo nuevo o mejora una entrada existente.</span>
        <span class="mt-4 inline-flex text-sm font-semibold text-geek-accent">Crear articulo</span>
      </a>
    </aside>
  </div>
</MainLayout>
