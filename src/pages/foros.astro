---
import MainLayout from '@/layouts/MainLayout.astro';
import {
  FORUM_GUIDELINES,
  FORUM_PAGE_STATS,
  FORUM_RADAR,
  FORUM_THREADS,
  HOME_IMAGES,
  ROUTES,
} from '@/shared/constants';

const leadThread = FORUM_THREADS[0];
---

<MainLayout title="Foros" description="Debates, teorias y soporte editorial de la comunidad NexoGeek">
  <section class="relative overflow-hidden rounded-lg border border-geek-border bg-geek-dark-secondary">
    <img src={HOME_IMAGES.hero} alt="" class="absolute inset-0 h-full w-full object-cover opacity-42" loading="eager" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-r from-geek-dark via-geek-dark/86 to-geek-dark/36" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-geek-dark-secondary to-transparent" aria-hidden="true"></div>

    <div class="relative grid min-h-[400px] gap-6 p-6 md:p-8 xl:grid-cols-[minmax(0,1fr)_380px] xl:p-10">
      <div class="flex max-w-3xl flex-col justify-center">
        <span class="mb-4 inline-flex w-fit rounded-lg border border-emerald-300/30 bg-emerald-300/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-100">
          Teorias y soporte editorial
        </span>
        <h1 class="text-4xl font-bold leading-tight text-white md:text-6xl">Foros</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-geek-text-secondary md:text-lg">
          Hilos de debate para resolver canon, proponer teorias y ayudar a convertir discusiones en articulos claros.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#debates" class="inline-flex h-11 items-center gap-2 rounded-lg bg-geek-accent-hover px-5 text-sm font-bold text-white transition-colors hover:bg-geek-accent focus-visible:ring-2 focus-visible:ring-geek-accent">
            Ver debates
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a href={ROUTES.ACTIVITY} class="inline-flex h-11 items-center rounded-lg border border-geek-border bg-geek-dark-secondary/80 px-5 text-sm font-semibold text-geek-text transition-colors hover:border-geek-accent/70 hover:bg-geek-dark-tertiary focus-visible:ring-2 focus-visible:ring-geek-accent">
            Ver actividad
          </a>
        </div>
      </div>

      <aside class="self-end rounded-lg border border-geek-border bg-geek-dark/76 p-4 backdrop-blur">
        <p class="text-xs uppercase tracking-wide text-geek-text-secondary">Hilo recomendado</p>
        <span class="mt-3 inline-flex rounded-md bg-emerald-300/10 px-2 py-1 text-xs font-semibold text-emerald-100">{leadThread.state}</span>
        <h2 class="mt-3 text-xl font-bold text-white">{leadThread.title}</h2>
        <p class="mt-2 text-sm leading-6 text-geek-text-secondary">{leadThread.summary}</p>
        <div class="mt-4 flex items-center justify-between rounded-lg border border-geek-border bg-geek-dark-secondary p-3">
          <span class="text-sm text-geek-text-secondary">{leadThread.category}</span>
          <span class="text-sm font-semibold text-geek-accent">{leadThread.replies} respuestas</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4" aria-label="Metricas de foros">
    {FORUM_PAGE_STATS.map((stat) => (
      <div class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <span class="block text-2xl font-bold text-white">{stat.value}</span>
        <span class="block text-sm font-semibold text-geek-text">{stat.label}</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">{stat.detail}</span>
      </div>
    ))}
  </section>

  <div class="mt-8 grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
    <div class="min-w-0 space-y-8">
      <section id="debates">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold text-white">Debates activos</h2>
            <p class="mt-1 text-sm text-geek-text-secondary">Hilos con destino editorial, categoria y estado visible.</p>
          </div>
          <a href={ROUTES.CREATE_ARTICLE} class="text-sm font-semibold text-geek-accent transition-colors hover:text-geek-accent-secondary">Crear desde debate</a>
        </div>

        <div class="grid gap-4 lg:grid-cols-2">
          {FORUM_THREADS.map((thread) => (
            <a href={thread.href} class="group rounded-lg border border-geek-border bg-geek-dark-secondary p-4 transition-colors hover:border-geek-accent/70 focus-visible:ring-2 focus-visible:ring-geek-accent">
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-md bg-emerald-300/10 px-2 py-1 text-xs font-semibold text-emerald-100">{thread.state}</span>
                <span class="rounded-md border border-geek-border bg-geek-dark px-2 py-1 text-xs text-geek-text-secondary">{thread.category}</span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-white group-hover:text-geek-accent-secondary">{thread.title}</h3>
              <p class="mt-2 text-sm leading-6 text-geek-text-secondary">{thread.summary}</p>
              <div class="mt-4 flex items-center justify-between border-t border-geek-border pt-3 text-sm">
                <span class="font-semibold text-geek-accent">{thread.replies} respuestas</span>
                <span class="text-geek-text-secondary">{thread.lastActive}</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section>
        <div class="mb-4">
          <h2 class="text-2xl font-bold text-white">Reglas rapidas</h2>
          <p class="mt-1 text-sm text-geek-text-secondary">Minimos para mantener debates utiles y convertibles en contenido.</p>
        </div>

        <div class="grid gap-3 md:grid-cols-3">
          {FORUM_GUIDELINES.map((guide) => (
            <div class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
              <h3 class="text-lg font-bold text-white">{guide.title}</h3>
              <p class="mt-2 text-sm leading-6 text-geek-text-secondary">{guide.detail}</p>
            </div>
          ))}
        </div>
      </section>
    </div>

    <aside class="space-y-4 xl:sticky xl:top-24 xl:self-start">
      <section class="rounded-lg border border-geek-border bg-geek-dark-secondary/70 p-4">
        <h2 class="text-base font-bold text-white">Radar de foros</h2>
        <div class="mt-4 space-y-2">
          {FORUM_RADAR.map((item) => (
            <a href={item.href} class="flex items-center justify-between rounded-lg border border-transparent px-3 py-2 transition-colors hover:border-geek-border hover:bg-geek-dark">
              <span class="text-sm font-semibold text-geek-text">{item.label}</span>
              <span class="rounded-md bg-geek-accent/10 px-2 py-1 text-xs font-semibold text-geek-accent">{item.count}</span>
            </a>
          ))}
        </div>
      </section>

      <a href={ROUTES.COLLABORATORS} class="block rounded-lg border border-geek-accent/30 bg-geek-accent/10 p-4 transition-colors hover:border-geek-accent/60 hover:bg-geek-accent/15">
        <span class="text-base font-bold text-white">Busca moderadores</span>
        <span class="mt-1 block text-sm text-geek-text-secondary">Encuentra colaboradores para cerrar hilos o revisar teorias.</span>
        <span class="mt-4 inline-flex text-sm font-semibold text-geek-accent">Ver colaboradores</span>
      </a>
    </aside>
  </div>
</MainLayout>
