---
import MainLayout from '@/layouts/MainLayout.astro';
import { ArticleReader } from '@/widgets/article-reader';
import { Card, Breadcrumb } from '@/shared/ui';
import { EditArticleLink } from '@/shared/ui/EditArticleLink';
import { ROUTES } from '@/shared/constants';
import { getSlugPaths, loadPageData } from '@/shared/lib';
import type { Article } from '@/entities/article';

export async function getStaticPaths() {
  return getSlugPaths('/articles?limit=50', [
    'que-es-el-ultra-instinto',
    'quien-es-doctor-doom',
  ]);
}

const { slug } = Astro.params;
const article = await loadPageData<Article | null>(`/articles/${slug}`, null);

if (!article) {
  return Astro.redirect('/404');
}

const relatedArticles = article.relatedArticles || [];
---

<MainLayout title={article.title} description={article.summary}>
  <Breadcrumb
    items={[
      { label: 'Inicio', href: ROUTES.HOME },
      { label: 'Artículos', href: ROUTES.ARTICLES },
      { label: article.title },
    ]}
  />

  <div class="flex flex-col lg:flex-row gap-8">
    <div class="flex-1 min-w-0">
      <div class="mb-4 flex justify-end">
        <EditArticleLink slug={article.slug} authorId={article.authorId} client:load />
      </div>
      <ArticleReader article={article} client:load />
    </div>

    <aside class="w-full lg:w-72 flex-shrink-0">
      {relatedArticles.length > 0 && (
        <div class="space-y-4">
          <Card>
            <h3 class="text-sm font-semibold text-geek-text-secondary uppercase tracking-wider mb-3">
              Artículos relacionados
            </h3>
            <div class="space-y-3">
              {relatedArticles.map((related) => (
                <a href={ROUTES.ARTICLE_DETAIL(related.slug)} class="block hover:bg-geek-dark-tertiary rounded-lg p-2 -mx-2 transition-colors">
                  <p class="text-sm font-medium text-geek-text line-clamp-1">{related.title}</p>
                  <p class="text-xs text-geek-text-secondary mt-0.5">{related.views} vistas</p>
                </a>
              ))}
            </div>
          </Card>
        </div>
      )}
    </aside>
  </div>
</MainLayout>
