---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { RegisterFormWithAuth } from '@/shared/ui/RegisterForm';
---

<AuthLayout title="Registro" description="Crea tu cuenta en NexoGeek">
  <div class="w-full max-w-md">
    <h1 class="mb-6 text-center font-heading text-2xl font-bold text-geek-text">Crear cuenta</h1>
    <RegisterFormWithAuth client:only="react" />
    <p class="mt-6 text-center text-sm text-geek-text-secondary">
      Ya tienes cuenta?{' '}
      <a href="/login" class="font-medium text-geek-accent hover:text-geek-accent-hover">Inicia sesion</a>
    </p>
  </div>
</AuthLayout>
