# ── Server ──────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values for production.

# Express listen port
PORT=3001

# `production` enforces stricter checks (JWT secrets required,
# `color-scheme` HSTS, etc.). Leave as `development` for local work.
NODE_ENV=development

# Comma-separated list of origins allowed by CORS. Add the deployed
# frontend URL here in production.
CORS_ORIGINS=http://localhost:4321,http://localhost:3000

# ── JWT secrets ────────────────────────────────────────────────
# REQUIRED in production. The server refuses to start if these
# are unset and NODE_ENV=production.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Load testing ────────────────────────────────────────────────
# Set to `true` to disable rate limiting. NEVER enable in production.
LOAD_TEST=false
